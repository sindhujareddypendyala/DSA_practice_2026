class Palindrome_Number {
    public boolean isPalindrome(int x) {
        int original = x;
        int rev = 0;
        int n = 0;

        if(x<0){
            return false;
        }

        while( x != 0){
        n = x % 10;
        rev = rev * 10 + n;
        x = x/10;
        }
         
        return original == rev;
    }
}